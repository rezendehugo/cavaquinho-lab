{
  "name": "cavaquinho-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=22",
    "npm": ">=11 <12"
  },
  "homepage": "https://rezendehugo.github.io/cavaquinho-lab",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm test",
    "validate": "npm run check && npm run build && npm run test:e2e",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run --environment jsdom",
    "dev:e2e": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "test:e2e": "start-server-and-test dev:e2e http://127.0.0.1:4173/cavaquinho-lab/ 'cypress run'",
    "test:e2e:open": "start-server-and-test dev:e2e http://127.0.0.1:4173/cavaquinho-lab/ 'cypress open'",
    "audit:chords": "node scripts/audit-chord-library.mjs"
  },
  "dependencies": {
    "@tombatossals/chords-db": "github:rezendehugo/chords-db#0186d2fe9b59f729fc86b4f8e3d7cfda40c4ac05",
    "@tombatossals/react-chords": "git+https://github.com/rezendehugo/react-chords.git#83bae79ebcffbc0351cfc7bb86670e8e6e511c34",
    "lucide-react": "^1.21.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.2",
    "cypress": "^15.18.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jsdom": "^27.3.0",
    "start-server-and-test": "^3.0.11",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
